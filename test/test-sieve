#!/bin/bash

#######################################
#                                     #
#        panSieve Test Suite         #
#                                     #
#######################################

##############################################################################
# Author: Nathaniel Cole (nc564@cornell.edu)                                 #
# Date: 08-04-25                                                             #
# Description: Test suite for panSieve script                               #
# Test Data Source:                                                         #
#   https://github.com/vgteam/vg/tree/master/test/graphs                    #
##############################################################################

# Enable strict error handling
set -euo pipefail

# Get the directory where the test script is located
TEST_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_DIR="$(cd "${TEST_DIR}/.." && pwd)"
DATA_DIR="${TEST_DIR}/data"
EXPECTED_DIR="${TEST_DIR}/expected"
TEMP_DIR="${TEST_DIR}/temp"

# Source the script to test internal functions
source "${SCRIPT_DIR}/src/sieve"

# Test counter
TESTS_RUN=0
TESTS_PASSED=0
TESTS_FAILED=0

# Colors for output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

extended=0
################################################################################
# Test Helper Functions                                                        #
################################################################################

setup() {
    echo "Setting up test environment..."
    mkdir -p "${TEMP_DIR}"
    mkdir -p "${EXPECTED_DIR}"
       
    if [[ $extended -eq 1 ]]; then
        # Test files categorization for extended tests
        COMPLEX_GRAPHS=("big_snarl_named.gfa" "difficult-inv.vg" "special_cases.gfa")
    else
        # Use minimal test data for basic tests
        SIMPLE_GRAPHS=("gfa_with_reference.gfa" "empty.gfa" "named.gfa" "three_samples.gfa")
    fi
}

cleanup() {
    echo "Cleaning up test environment..."
    if [[ -d "${TEMP_DIR}" ]]; then
        rm -rfv "${TEMP_DIR}"
    fi
    echo -e "${GREEN}Cleanup complete${NC}"
}

assert() {
    local message=$1
    local command=$2
    ((TESTS_RUN++))
    
    echo -e "${YELLOW}Test #${TESTS_RUN}${NC}: $message"
    echo "Running command: $command"
    
    if eval "$command"; then
        echo -e "${GREEN}✓ PASSED${NC}"
        ((TESTS_PASSED++))
        echo "---"
        return 0
    else
        echo -e "${RED}✗ FAILED${NC}"
        ((TESTS_FAILED++))
        echo "---"
        return 1
    fi
}

run_test() {
    local test_name=$1
    local test_function=$2
    
    echo "Running test: $test_name"
    if $test_function; then
        echo -e "${GREEN}Test completed successfully${NC}"
    else
        echo -e "${RED}Test failed${NC}"
    fi
    echo
}

################################################################################
# Test Cases                                                                  #
################################################################################

test_script_exists() {
    assert "script exists" "[[ -f ${SCRIPT_DIR}/sieve ]]"
}

test_script_executable() {
    assert "script is executable" "[[ -x ${SCRIPT_DIR}/sieve ]]"
}

test_help_output() {
    assert "help output contains usage" "${SCRIPT_DIR}/sieve --help 2>&1 | grep 'Usage:'"
}

test_version_output() {
    assert "version output" "${SCRIPT_DIR}/sieve --version 2>&1 | grep 'version'"
}

test_input_validation() {
    # Test missing input file
    assert "detects missing input" "! ${SCRIPT_DIR}/sieve -i nonexistent.gfa 2>/dev/null"
    
    # Test empty input file
    assert "detects empty input" "! ${SCRIPT_DIR}/sieve -i ${DATA_DIR}/empty.gfa 2>/dev/null"
    
    # Test invalid input file
    assert "detects invalid input" "! ${SCRIPT_DIR}/sieve -i ${DATA_DIR}/invalid.gfa 2>/dev/null"
}

test_missing_arguments() {
    assert "detects missing arguments" \
        "${SCRIPT_DIR}/sieve 2>&1 | grep 'Missing required arguments'"
}

test_dry_run() {
    assert "dry run mode works" "${SCRIPT_DIR}/sieve -i ${DATA_DIR}/gfa_with_reference.gfa --dry-run | grep 'Would execute'"
}

test_simple_graphs() {
    local test_output="${TEMP_DIR}/simple"
    mkdir -p "$test_output"
    
    echo -e "\n${YELLOW}Testing simple graphs...${NC}"
    
    for graph in "${SIMPLE_GRAPHS[@]}"; do
        local base_name=$(basename "${graph%.*}")
        
        assert "processes simple graph ${graph}" \
            "${SCRIPT_DIR}/sieve -i ${DATA_DIR}/${graph} -o ${test_output}/${base_name}"
        
        assert "creates output for ${graph}" \
            "[[ -f ${test_output}/${base_name}/sieved-pangenome.fa ]]"
        
        assert "generates statistics for ${graph}" \
            "[[ -f ${test_output}/${base_name}/sieved-pangenome.stats ]]"
        
        # Validate FASTA format
        if [[ -f "${test_output}/${base_name}/sieved-pangenome.fa" ]]; then
            assert "validates FASTA format for ${graph}" \
                "grep '^>' ${test_output}/${base_name}/sieved-pangenome.fa"
        fi
    done
}

test_complex_graphs() {
    local test_output="${TEMP_DIR}/complex"
    mkdir -p "$test_output"
    
    echo -e "\n${YELLOW}Testing complex graphs...${NC}"
    
    for graph in "${COMPLEX_GRAPHS[@]}"; do
        local base_name=$(basename "${graph%.*}")
        
        assert "processes complex graph ${graph}" \
            "${SCRIPT_DIR}/sieve -i ${DATA_DIR}/${graph} -o ${test_output}/${base_name}"
        
        assert "creates output for ${graph}" \
            "[[ -f ${test_output}/${base_name}/sieved-pangenome.fa ]]"
        
        assert "generates statistics for ${graph}" \
            "[[ -f ${test_output}/${base_name}/sieved-pangenome.stats ]]"
    done
}

test_edge_cases() {
    local test_output="${TEMP_DIR}/edge_cases"
    mkdir -p "$test_output"
    
    echo -e "\n${YELLOW}Testing edge cases...${NC}"
    
    for graph in "${EDGE_CASES[@]}"; do
        local base_name=$(basename "${graph%.*}")
        
        # These cases might fail, but should fail gracefully
        assert "handles edge case ${graph} gracefully" \
            "{ ${SCRIPT_DIR}/sieve -i ${DATA_DIR}/${graph} -o ${test_output}/${base_name} 2>&1 || true; } | grep 'ERROR:'"
    done
}

test_compressed_input() {
    local test_output="${TEMP_DIR}/compressed"
    mkdir -p "$test_output"
    
    echo -e "\n${YELLOW}Testing compressed input...${NC}"
    
    # Create a compressed version of the test file
    gzip -c "${DATA_DIR}/gfa_with_reference.gfa" > "${test_output}/compressed.gfa.gz"
    
    # Verify the compressed file was created
    if [[ ! -f "${test_output}/compressed.gfa.gz" ]]; then
        log_error "Failed to create compressed test file"
        return 1
    fi
    
    assert "handles compressed input" \
        "${SCRIPT_DIR}/sieve -i ${test_output}/compressed.gfa.gz -o ${test_output}/compressed_out"
}

test_output_creation() {
    # Test with valid input
    rm -rf "${TEMP_DIR}/output"
    assert "creates output directory" "${SCRIPT_DIR}/sieve -i ${DATA_DIR}/gfa_with_reference.gfa -o ${TEMP_DIR}/output"
    assert "output directory exists" "[[ -d ${TEMP_DIR}/output ]]"
    assert "generates FASTA output" "[[ -f ${TEMP_DIR}/output/sieved-pangenome.fa ]]"
}

test_stats_generation() {
    rm -rf "${TEMP_DIR}/output_stats"
    assert "generates statistics" "${SCRIPT_DIR}/sieve -i ${DATA_DIR}/gfa_with_reference.gfa -o ${TEMP_DIR}/output_stats --stats"
    assert "statistics file exists" "[[ -f ${TEMP_DIR}/output_stats/sieved-pangenome.stats ]]"
}

test_keep_temp_files() {
    rm -rf "${TEMP_DIR}/output_temp"
    
    assert "keeps temporary files" \
        "${SCRIPT_DIR}/sieve -i ${DATA_DIR}/gfa_with_reference.gfa -o ${TEMP_DIR}/output_temp --keep-temp"
    
    # Check if tmp directory exists
    assert "temporary directory exists" \
        "[[ -d ${TEMP_DIR}/output_temp ]]"
    
    # Optional: Check if files are in the tmp directory
    if [[ -d "${TEMP_DIR}/output_temp/tmp" ]]; then
        [[ "$DEBUG" == "true" ]] && log_debug "Temporary directory contains: $(ls -la ${TEMP_DIR}/output_temp/tmp)"
    fi
}

test_verbose_output() {
    assert "verbose mode provides additional output" \
        "${SCRIPT_DIR}/sieve -i ${DATA_DIR}/gfa_with_reference.gfa -o ${TEMP_DIR}/output_verbose -v --dry-run 2>&1 | grep 'INFO:'"
}

test_debug_output() {
    assert "debug mode provides detailed output" \
        "${SCRIPT_DIR}/sieve -i ${DATA_DIR}/gfa_with_reference.gfa -o ${TEMP_DIR}/output_debug -d --dry-run 2>&1 | grep 'DEBUG:'"
}

################################################################################
# Main Test Execution                                                         #
################################################################################

main() {
    echo "==========================================="
    echo "Starting panSieve Test Suite"
    echo "==========================================="
    echo
    
    # Setup test environment
    setup
    
    # Run tests
    echo "Running tests..."
    echo
    
    run_test "Script Existence" test_script_exists
    run_test "Script Executable" test_script_executable
    run_test "Help Output" test_help_output
    run_test "Version Output" test_version_output
    run_test "Missing Arguments" test_missing_arguments
    run_test "Input Validation" test_input_validation
    run_test "Dry Run" test_dry_run
    run_test "Output Creation" test_output_creation
    run_test "Compressed Input" test_compressed_input
    run_test "Statistics Generation" test_stats_generation
    run_test "Keep Temp Files" test_keep_temp_files
    run_test "Verbose Output" test_verbose_output
    run_test "Debug Output" test_debug_output

    if [[ $extended -eq 1 ]]; then
        run_test "VG Simple Test Graphs" test_simple_graphs
        run_test "VG Complex Test Graphs" test_complex_graphs
        run_test "VG Edge Case Test Graphs" test_edge_cases
    fi
    
    # Cleanup
    cleanup
    
    # Print summary
    echo "==========================================="
    echo -e "${YELLOW}Test Summary:${NC}"
    echo "  Total tests: ${TESTS_RUN}"
    echo -e "  ${GREEN}Passed: ${TESTS_PASSED}${NC}"
    if [[ ${TESTS_FAILED} -gt 0 ]]; then
        echo -e "  ${RED}Failed: ${TESTS_FAILED}${NC}"
    else
        echo "  Failed: 0"
    fi
    echo "==========================================="
    
    # Return appropriate exit code
    [[ ${TESTS_FAILED} -eq 0 ]]
}

if [[ "${1:-}" == "--extended" ]]; then
    extended=1
    shift
fi

# Run tests if script is executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi