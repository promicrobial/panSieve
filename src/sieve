# panExtract
# This tool processes a pangenome graph file (GFA or GFA.gz) and extracts
# non-redundant sequences, including the reference and unique variants.
# It converts the graph to vg format, indexes it, extracts paths, generates variants,
# and applies these variants to a reference sequence to create a non-redundant set of sequences.

# Enable strict error handling
set -euo pipefail
# -e: Exit immediately if a command exits with non-zero status
# -u: Treat unset variables as an error
# -o pipefail: Return value of a pipeline is the status of the last command to exit with a non-zero status

# Usage function to display help message
usage() {
    echo "Usage: "$0" <input.gfa[.gz]> <config_file>"
    echo
    echo "This script processes a variant graph file (GFA or GFA.gz) and extracts"
    echo "non-redundant sequences, including the reference and unique variants."
    echo
    echo "Arguments:"
    echo "  <input.gfa[.gz]>  Input GFA file (can be gzipped)"
    echo "  <config_file>     Configuration file containing paths and settings"
    echo
    echo "The config file should contain the following variables:"
    echo "  VG_PATH           Path to the vg executable"
    echo "  OUTPUT_DIR        Directory to store output files"
    echo "  OUTPUT_FILENAME   Desired name for the output file (use .fa for FASTA or .fastq for FASTQ)"
    echo
    echo "Example config file content:"
    echo "VG_PATH=/path/to/vg"
    echo "OUTPUT_DIR=/path/to/output/directory"
    echo "OUTPUT_FILENAME=output.fa"
    echo
    echo "Note: This script requires bcftools and seqtk to be installed and available in your PATH."
}

# Display usage if no arguments are provided or if -h/--help is used
if [ "$#" -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
    exit 0
fi

# Check if correct number of arguments is provided
if [ "$#" -ne 2 ]; then
    echo "Error: Incorrect number of arguments." >&2
    usage
    exit 1
fi

# Assign input arguments to variables
INPUT_GFA=$1  # Input GFA file
CONFIG_FILE=$2  # Configuration file

# Check if config file exists and read it
if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: Config file not found: $CONFIG_FILE" >&2
    exit 1
fi
source "$CONFIG_FILE"  # Read the config file

# Check if required variables are set in the config file
if [ -z "$VG_PATH" ] || [ -z "$OUTPUT_DIR" ] || [ -z "$OUTPUT_FILENAME" ]; then
    echo "Error: VG_PATH, OUTPUT_DIR, and OUTPUT_FILENAME must be set in the config file." >&2
    exit 1
fi

# Create output directory if it doesn't exist
mkdir -p "$OUTPUT_DIR"

# Determine if input is gzipped and set appropriate command
if [[ $INPUT_GFA == *.gz ]]; then
    DECOMPRESS="gunzip -c"  # If input is gzipped, use gunzip to decompress
else
    DECOMPRESS="cat"  # If input is not gzipped, just use cat to output file contents
fi

# Convert GFA to vg format
echo "Converting GFA to vg format..."
$DECOMPRESS "$INPUT_GFA" | "$VG_PATH" convert -g - > "$OUTPUT_DIR/graph.vg"

# Index the graph
echo "Indexing the graph..."
"$VG_PATH" index -x "$OUTPUT_DIR/graph.xg" "$OUTPUT_DIR/graph.vg"

# Extract reference samples from the RS tag
echo "Identifying reference samples..."
REFERENCE_SAMPLES=$($DECOMPRESS "$INPUT_GFA" | grep "^H" | grep "RS:Z:" | sed 's/.*RS:Z://' | tr ' ' '\n' | sort | uniq)

if [[ ! -v "$REFERENCE_SAMPLES" ]]; then
  echo "No reference sequence found"
  exit 1
fi

# Extract reference sequences and generate VCFs
for REF_PREFIX in $REFERENCE_SAMPLES; do
    echo "Processing reference: $REF_PREFIX"
    
    # Extract reference sequence in FASTA format
    echo "Extracting reference sequence for $REF_PREFIX..."
    "$VG_PATH" paths -F --paths-by "$REF_PREFIX" -x "$OUTPUT_DIR/graph.xg" > "$OUTPUT_DIR/${REF_PREFIX}_reference.fa"
    
    # Get the name of the extracted reference path
    REFERENCE_PATH=$(grep "^>" "$OUTPUT_DIR/${REF_PREFIX}_reference.fa" | head -n 1 | sed 's/^>//')
    
    echo "Extracted reference path: $REFERENCE_PATH"
    
    # Generate VCF of variants
    echo "Generating VCF of variants for $REF_PREFIX..."
    "$VG_PATH" deconstruct -p "$REFERENCE_PATH" -e -a "$OUTPUT_DIR/graph.xg" > "$OUTPUT_DIR/${REF_PREFIX}_variants.vcf"
    
    # Compress and index the VCF
    echo "Compressing and indexing VCF for $REF_PREFIX..."
    bgzip "$OUTPUT_DIR/${REF_PREFIX}_variants.vcf" -o "$OUTPUT_DIR/${REF_PREFIX}_variants.vcf.gz"
    tabix -p vcf "$OUTPUT_DIR/${REF_PREFIX}_variants.vcf.gz"

    # Apply variants to reference
    echo "Applying variants to reference for $REF_PREFIX..."
    bcftools consensus --fasta-ref "$OUTPUT_DIR/${REF_PREFIX}_reference.fa" "$OUTPUT_DIR/${REF_PREFIX}_variants.vcf.gz" > "$OUTPUT_DIR/${REF_PREFIX}_${OUTPUT_FILENAME}"
done

# Combine all reference sequences into a single file
cat "$OUTPUT_DIR"/*_"${OUTPUT_FILENAME}" > "$OUTPUT_DIR/${OUTPUT_FILENAME}"

# Convert to FASTQ if requested (based on output filename extension)
if [[ $OUTPUT_FILENAME == *.fastq ]]; then
    echo "Converting to FASTQ..."
    seqtk seq -F '#' "$OUTPUT_DIR/${OUTPUT_FILENAME}" > "$OUTPUT_DIR/${OUTPUT_FILENAME}.tmp" && mv "$OUTPUT_DIR/${OUTPUT_FILENAME}.tmp" "$OUTPUT_DIR/${OUTPUT_FILENAME}"
fi

echo "Process completed. Output saved to $OUTPUT_DIR/${OUTPUT_FILENAME}"

# Clean up intermediate files
rm -f "$OUTPUT_DIR"/*_reference.fa "$OUTPUT_DIR"/*_variants.vcf* "$OUTPUT_DIR"/*_"${OUTPUT_FILENAME}"

echo "Intermediate files cleaned up."